{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watchtower",
  "version": "3.5.18",
  "identifier": "cloud.nykon.watchtower",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Watchtower",
        "width": 920,
        "height": 800,
        "url": "/"
      },
      {
        "label": "idle",
        "title": "Idle time alert",
        "width": 500,
        "height": 450,
        "url": "/idle",
        "visible": false,
        "center": true,
        "resizable": false,
        "closable": true,
        "minimizable": true
      },
      {
        "label": "quit",
        "title": "Pending Uploads",
        "width": 400,
        "height": 300,
        "url": "/quit",
        "visible": false,
        "center": true,
        "resizable": false,
        "closable": false,
        "minimizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "macOS": {
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "height": 400,
          "width": 660
        }
      },
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "Developer ID Application: Emmanuel Ahman (BKV8QDHR64)"
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/*"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://jujjlgwwuhxhjxlkxcfn.supabase.co/storage/v1/object/public/app-releases/latest/update.json?v=test1"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwRDEyNEE0ODNDQTMwQkYKUldTL01NcURwQ1RSUU9HbzI0VFRWdXI5Zm9UNlVPdFF1L09Gd0NtRUszMEdNQmxqRnB0ZENkMnAK",
      "dialog": true
    }
  }
}
